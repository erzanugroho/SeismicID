# Keep Docker build context small + reproducible.
# We COPY only backend/ frontend/ scripts/ + requirements.txt, but trimming
# the context speeds up the build and avoids leaking local state.
.git
.gitignore
.venv
.venv-wsl
__pycache__
**/__pycache__
*.pyc
.pytest_cache
.mypy_cache
.ruff_cache
data
logs
docs
*.ps1
.env
.env.*
nixpacks.toml
README.md
backend/tests
requirements-dev.txt
