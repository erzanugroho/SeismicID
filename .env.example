# Earthquake Probability Forecast System — Environment Variables

# App
APP_NAME=gempa-forecast
APP_VERSION=0.1.0
APP_ENV=development
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# Data paths (relative to project root)
DATA_DIR=data
PARQUET_DIR=data/parquet
SQLITE_PATH=data/sqlite/gempa.db
MODELS_DIR=data/models
GEO_DIR=data/geo

# Indonesia bounding box
GRID_LAT_MIN=-11.0
GRID_LAT_MAX=6.0
GRID_LON_MIN=95.0
GRID_LON_MAX=141.0
GRID_STEP=0.5

# External APIs
USGS_BASE_URL=https://earthquake.usgs.gov/fdsnws/event/1/query
BMKG_AUTOGEMPA_URL=https://data.bmkg.go.id/DataMKG/TEWS/autogempa.json
BMKG_TERKINI_URL=https://data.bmkg.go.id/DataMKG/TEWS/gempaterkini.json
BMKG_DIRASAKAN_URL=https://data.bmkg.go.id/DataMKG/TEWS/gempadirasakan.json

# Scheduler intervals (minutes for fetch/forecast, cron for retrain)
SCHED_REALTIME_FETCH_MIN=15
SCHED_FORECAST_RECOMPUTE_MIN=60
SCHED_RETRAIN_CRON_DAY=sun
SCHED_RETRAIN_CRON_HOUR=2

# GPU Training (set true jika ada NVIDIA GPU + CUDA)
USE_GPU=false

# Forecast defaults
DEFAULT_HORIZON_DAYS=30
DEFAULT_MAG_THRESHOLD=5.0

# CORS
CORS_ALLOW_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
