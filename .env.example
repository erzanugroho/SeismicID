# Earthquake Probability Forecast System — Environment Variables

# App
APP_NAME=gempa-forecast
APP_VERSION=0.1.0
APP_ENV=development
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# Data paths (relative to project root)
DATA_DIR=data
PARQUET_DIR=data/parquet
SQLITE_PATH=data/sqlite/gempa_runtime.db
MODELS_DIR=data/models
GEO_DIR=data/geo

# Indonesia bounding box
GRID_LAT_MIN=-11.0
GRID_LAT_MAX=6.0
GRID_LON_MIN=95.0
GRID_LON_MAX=141.0
GRID_STEP=0.5

# External APIs
USGS_BASE_URL=https://earthquake.usgs.gov/fdsnws/event/1/query
BMKG_AUTOGEMPA_URL=https://data.bmkg.go.id/DataMKG/TEWS/autogempa.json
BMKG_TERKINI_URL=https://data.bmkg.go.id/DataMKG/TEWS/gempaterkini.json
BMKG_DIRASAKAN_URL=https://data.bmkg.go.id/DataMKG/TEWS/gempadirasakan.json
# BMKG public realtime page (Nuxt SSR) — exposes 100-200 records incl. micro-quakes M~2.0+
BMKG_REALTIME_URL=https://www.bmkg.go.id/gempabumi/gempabumi-realtime.bmkg
# EMSC FDSN-WS event service (alternative source, FDSN protocol like USGS)
EMSC_BASE_URL=https://www.seismicportal.eu/fdsnws/event/1/query

# Admin / protected heavy endpoints
# Set this in local/Railway env to enable POST /api/forecasts/run and scheduler triggers.
# Public UI does not need this; it only reads cached forecasts.
ADMIN_TOKEN=change-me-dev-token

# Telegram alerts (optional; set in Railway env, do not commit real token)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERT_MIN_PROBABILITY=0.03
TELEGRAM_SIGNIFICANT_ABS_DELTA=0.005
TELEGRAM_SIGNIFICANT_REL_DELTA=0.25
# 00 UTC = 07 WIB
TELEGRAM_DAILY_REPORT_HOUR_UTC=0

# AI MVP v1 (optional; safe fallback when disabled)
AI_ENABLED=false
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_CHAT_URL=https://api.openai.com/v1/chat/completions
AI_TIMEOUT_SECONDS=20
AI_CACHE_TTL_MINUTES=360

# Scheduler intervals (legacy in-process scheduler; minutes for fetch/forecast, cron for retrain)
SCHED_REALTIME_FETCH_MIN=10
SCHED_FORECAST_RECOMPUTE_MIN=180
SCHED_RETRAIN_CRON_DAY=sun
SCHED_RETRAIN_CRON_HOUR=2

# Forecast worker policy (used by scripts/scheduler_tick.py / Railway cron)
FORECAST_TRIGGER_MODE=any_new_event
FORECAST_FETCH_INTERVAL_MINUTES=10
FORECAST_DEBOUNCE_MINUTES=5
FORECAST_FALLBACK_HOURS=3
# How far back each tick fetches USGS/EMSC. Larger = more resilient to worker outages.
FORECAST_LOOKBACK_HOURS=72

# For test/cron-only deployments you may disable the in-process APScheduler in the web service.
# DISABLE_SCHEDULER=1

# GPU Training (set true jika ada NVIDIA GPU + CUDA)
USE_GPU=false

# Forecast defaults
DEFAULT_HORIZON_DAYS=30
DEFAULT_MAG_THRESHOLD=5.0

# CORS
CORS_ALLOW_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
